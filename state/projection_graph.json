{
  "projection_type": "orbitalops.executive_view",

  "root": {
    "id": "executive_dashboard",

    "children": [

      {
        "id": "executive_summary",

        "priority": 1,

        "bindings": [

          "identity.mission_name",
          "identity.scenario",
          "identity.simulation_id",

          "runtime.timestamp",
          "runtime.phase",
          "runtime.state",

          "mission.overall_health",
          "mission.continuity_status",
          "mission.autonomous_response",
          "mission.mission_impact",

          "continuity.mission_continuity_score",

          "working_memory.current_objective",
          "working_memory.active_problem",

          "output.next_expected_state",

          "continuity.reconstruction_confidence",
          "continuity.replayability"
        ]
      },

      {
        "id": "mission_continuity",

        "priority": 2,

        "bindings": [

          "stable_memory.continuity_principle",

          "lineage.checkpoint_id",
          "lineage.parent_checkpoint",
          "lineage.root_checkpoint",
          "lineage.branch",

          "continuity.continuity_integrity",

          "autonomous_response.status",
          "autonomous_response.progress_percent",
          "autonomous_response.expected_completion"
        ]
      },

      {
        "id": "space_weather",

        "priority": 3,

        "bindings": [

          "solar_event.event_type",
          "solar_event.status",
          "solar_event.severity",

          "solar_event.detected_at",

          "solar_event.estimated_duration_seconds",

          "solar_event.radiation_index",

          "solar_event.affected_region.orbital_band"
        ]
      },

      {
        "id": "network_status",

        "priority": 4,

        "bindings": [

          "network.network_health",

          "telemetry.link_quality_percent",

          "network.throughput_gbps",

          "network.average_latency_ms",

          "network.packets_routed",
          "network.packets_received",
          "network.packets_sent",

          "network.dropped_packets",
          "network.rerouted_packets",

          "telemetry.packet_loss_percent"
        ]
      },

      {
        "id": "constellation_status",

        "priority": 5,

        "bindings": [

          "fleet.satellites.total",
          "fleet.satellites.healthy",
          "fleet.satellites.degraded",
          "fleet.satellites.offline",

          "fleet.relays.total",
          "fleet.relays.healthy",
          "fleet.relays.degraded",

          "fleet.ground_stations.total",
          "fleet.ground_stations.healthy"
        ]
      },

      {
        "id": "fleet_telemetry",

        "priority": 6,

        "bindings": [

          "telemetry.fleet_average_battery",
          "telemetry.fleet_average_temperature_c",
          "telemetry.fleet_average_cpu_percent",
          "telemetry.fleet_average_signal_strength"
        ]
      },

      {
        "id": "relay_network",

        "priority": 7,

        "entity_group": "relay",

        "entity_bindings": [

          "relay.alpha.status",
          "relay.alpha.utilization_percent",

          "relay.bravo.status",
          "relay.bravo.utilization_percent",
          "relay.bravo.anomaly.type",
          "relay.bravo.anomaly.severity",

          "relay.charlie.status",
          "relay.charlie.utilization_percent",

          "relay.delta.status",
          "relay.delta.utilization_percent"
        ]
      },

      {
        "id": "affected_satellites",

        "priority": 8,

        "entity_group": "satellite",

        "entity_bindings": [

          "satellite.SAT_12.*",
          "satellite.SAT_17.*",
          "satellite.SAT_18.*",
          "satellite.SAT_23.*",

          "topology.primary_route.SAT_12.relay",
          "topology.primary_route.SAT_17.relay",
          "topology.primary_route.SAT_18.relay",
          "topology.primary_route.SAT_23.relay",

          "topology.reroute_plan.SAT_12.target_relay",
          "topology.reroute_plan.SAT_17.target_relay",
          "topology.reroute_plan.SAT_18.target_relay",
          "topology.reroute_plan.SAT_23.target_relay"
        ]
      },

      {
        "id": "topology_view",

        "priority": 9,

        "bindings": [

          "stable_memory.topology.satellites",
          "stable_memory.topology.relays",
          "stable_memory.topology.ground_stations"
        ],

        "relationships": [

          {
            "from": "SAT_12",
            "current": "Relay_Bravo",
            "target": "Relay_Charlie"
          },

          {
            "from": "SAT_17",
            "current": "Relay_Bravo",
            "target": "Relay_Charlie"
          },

          {
            "from": "SAT_18",
            "current": "Relay_Bravo",
            "target": "Relay_Delta"
          },

          {
            "from": "SAT_23",
            "current": "Relay_Bravo",
            "target": "Relay_Delta"
          }
        ]
      },

      {
        "id": "active_anomalies",

        "priority": 10,

        "bindings": [

          "relay.bravo.anomaly.type",
          "relay.bravo.anomaly.severity",

          "satellite.SAT_12.anomaly.type",
          "satellite.SAT_17.anomaly.type",
          "satellite.SAT_18.anomaly.type",
          "satellite.SAT_23.anomaly.type",

          "solar_event.event_type",
          "solar_event.status"
        ]
      },

      {
        "id": "event_timeline",

        "priority": 11,

        "bindings": [

          "event_feed.T55",
          "event_feed.T56",
          "event_feed.T58",

          "event_feed.T59_SIGNAL_NOISE",
          "event_feed.T59_RADIATION_INTERFERENCE",

          "event_feed.T60_PACKET_LOSS",
          "event_feed.T60_LINK_DEGRADATION",

          "event_feed.T61_AUTONOMOUS_RECOVERY"
        ]
      },

      {
        "id": "semantic_delta",

        "priority": 12,

        "bindings": [

          "semantic_delta.added.solar_event_detected",
          "semantic_delta.added.relay_bravo_degraded",
          "semantic_delta.added.four_satellites_degraded",
          "semantic_delta.added.autonomous_recovery_started",

          "semantic_delta.modified.network_health",
          "semantic_delta.modified.latency",
          "semantic_delta.modified.route_assignments"
        ]
      },

      {
        "id": "autonomous_response",

        "priority": 13,

        "bindings": [

          "autonomous_response.status",
          "autonomous_response.current_action",
          "autonomous_response.progress_percent",
          "autonomous_response.expected_completion"
        ]
      }
    ]
  }
}